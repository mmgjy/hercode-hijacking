# Copy to .env and adjust. Never commit a real .env (see ../.gitignore).

# Runtime
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# Database. SQLite is the zero-config default for demo/tests.
# For PostgreSQL / Supabase use e.g.:
#   postgresql+psycopg://user:pass@host:5432/hijacking
DATABASE_URL=sqlite:///./hijacking.db

# Supabase (optional). The service-role key is server-side ONLY.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=snapshots
STORAGE_DIR=./storage

# CORS: comma-separated origins, or * for all (dev only).
ALLOWED_ORIGINS=*

# Outbound fetch safety
SCAN_TIMEOUT_SECONDS=15
SCAN_MAX_RESPONSE_BYTES=5000000
SCAN_PER_DOMAIN_RATE_PER_MINUTE=20
PLAYWRIGHT_ENABLED=false

# Optional shared secret. When set, mutating endpoints require X-API-Key.
API_KEY=
